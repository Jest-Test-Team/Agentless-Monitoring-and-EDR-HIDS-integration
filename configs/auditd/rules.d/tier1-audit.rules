# Tier 1 Auditd Rules — Internal Service VM
# Source: TIER-MONITORING-STRATEGY.md
# Deploy: augenrules --load

# System critical files
-w /etc/passwd -p wa -k passwd_change
-w /etc/shadow -p wa -k shadow_change
-w /etc/sudoers -p wa -k sudoers_change
-w /etc/group -p wa -k group_change

# SSH monitoring
-w /var/log/secure -p wa -k ssh_login
-w /etc/ssh/sshd_config -p wa -k ssh_config

# Process execution monitoring
-a always,exit -F arch=b64 -S execve -k process_exec
-a always,exit -F arch=b32 -S execve -k process_exec

# Package changes
-w /usr/bin/rpm -p x -k package_change
-w /usr/bin/dnf -p x -k package_change
-w /usr/bin/yum -p x -k package_change

# Wazuh agent
-w /var/ossec/ -p wa -k wazuh_agent

# Time changes
-a always,exit -F arch=b64 -S adjtimex -S settimeofday -S clock_settime -k time_change
